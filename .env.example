# =============================================================================
# TEMPLATE ONLY — copy this file to .env.local and paste YOUR real values there.
# Never commit .env.local to Git. Never put real secrets in .env.example.
# Step-by-step: docs/PASTE_SECRETS_HERE.md
# =============================================================================

# --- 1) Paste Project URL (Supabase → Settings → API → Project URL) ----------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# --- 2) Paste anon / publishable key (same API page, "anon" or publishable) ---
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_publishable_key

# --- 3) Paste service_role secret (same API page — "Reveal" service role) -----
# Needed for: Browse sample projects (server API only). Never use NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_secret

# --- 4) Optional: admin UI hint (your email) -----------------------------------
ADMIN_EMAIL=your-recipient-email@domain.com
NEXT_PUBLIC_ADMIN_EMAIL=your-recipient-email@domain.com

# --- 4b) Email notifications (Resend) ------------------------------------------
RESEND_API_KEY=re_your_resend_api_secret_key

# --- 5) M-Pesa (Daraja STK Push sandbox) -------------------------------------
MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd4b06f7d4e6b88f5a6f8aee0f
MPESA_CALLBACK_URL=https://your-public-url.example.com/api/payments/mpesa/callback

# --- 6) AI Studio / Gemini ---------------------------------------------------
GEMINI_API_KEY=paste_gemini_api_key_here
APP_URL=paste_app_url_here

# --- 7) Headless WordPress integration --------------------------------------
# If empty, the application falls back safely to internal high-fidelity local posts.
# To connect your remote WordPress instance, paste the standard clean URL here.
# Example: WORDPRESS_API_URL=https://public-api.wordpress.com/wp/v2/sites/yourblog.wordpress.com
# Or self-hosted: WORDPRESS_API_URL=https://www.yourwordpresssite.com
WORDPRESS_API_URL=

# Headless WP Layout Overrides: index tuning (0-indexed)
WORDPRESS_HERO_INDEX=0
WORDPRESS_GRID_START=1
WORDPRESS_GRID_COUNT=2


